# Copy to .env and adjust as needed:
#   cp .env.example .env
#
# Used by Docker Compose and (when present) local runs via python-dotenv.
# All variables are optional — defaults work for a local demo.

# ---------------------------------------------------------------------------
# Core / logging
# ---------------------------------------------------------------------------
# Log Grade B+ passes and MEDIUM/HIGH conjunctions to SQLite (data/starshield.db)
STARSHIELD_DB_LOG=1

# ---------------------------------------------------------------------------
# API / Streamlit
# ---------------------------------------------------------------------------
STARSHIELD_API_HOST=0.0.0.0
STARSHIELD_API_PORT=8000
STARSHIELD_STREAMLIT_PORT=8501
# When 1, Streamlit prefers HTTP API if reachable (set API_URL to the API base)
STARSHIELD_USE_API=0
STARSHIELD_API_URL=http://127.0.0.1:8000
STARSHIELD_SCHEDULE_ENABLED=1

# ---------------------------------------------------------------------------
# Rate limiting (per client IP)
#   STARSHIELD_API_RATE_LIMIT=0  → disable all quotas (handy for local scripts)
#   PUBLIC  = /health, /objects/*, list watchlists
#   DEFAULT = /history/* and most other routes
#   HEAVY   = /passes, /watchlist/*/scan, /export/*  (expensive)
# ---------------------------------------------------------------------------
STARSHIELD_API_RATE_LIMIT=1
STARSHIELD_API_RATE_LIMIT_DEFAULT=60/minute
STARSHIELD_API_RATE_LIMIT_HEAVY=20/minute
STARSHIELD_API_RATE_LIMIT_PUBLIC=120/minute

# ---------------------------------------------------------------------------
# API authentication (X-API-Key header)
# Off by default for local demos. Generate a key:
#   python main.py apikey --cmd generate
# ---------------------------------------------------------------------------
STARSHIELD_API_KEY_REQUIRED=0
# Comma-separated keys and/or keys in data/api_keys.txt
# STARSHIELD_API_KEYS=dev-key-one,dev-key-two
# Client key used by Streamlit when USE_API=1
# STARSHIELD_API_KEY=dev-key-one

# ---------------------------------------------------------------------------
# Debris in Object Index
#   auto  = include a debris group only if its TLE cache exists under data/
#           (recommended — fetch first: python main.py debris --cmd fetch)
#   1     = always list debris groups (empty until you fetch)
#   0     = never index debris, even if cached
# ---------------------------------------------------------------------------
STARSHIELD_INDEX_DEBRIS=auto

# ---------------------------------------------------------------------------
# Webhook notifications (optional)
# Fires on Grade B+ passes and MEDIUM/HIGH conjunctions when a URL is set.
# Test: python main.py notify --cmd test
# ---------------------------------------------------------------------------
STARSHIELD_NOTIFY_ENABLED=1
# Comma-separated webhook URLs (generic HTTP POST JSON)
# STARSHIELD_WEBHOOK_URL=https://hooks.example.com/starshield
# STARSHIELD_WEBHOOK_URLS=https://a.example/hook,https://b.example/hook
# Or: python main.py notify --cmd init  → edit data/notifications.json
#     (format: generic | discord | slack)
STARSHIELD_NOTIFY_PASS_MIN_SCORE=70
STARSHIELD_NOTIFY_PASS_MIN_GRADE=B
STARSHIELD_NOTIFY_CONJ_RISKS=HIGH,MEDIUM
# STARSHIELD_NOTIFY_ASYNC=1
# STARSHIELD_NOTIFY_TIMEOUT=8

# ---------------------------------------------------------------------------
# Risk thresholds (code defaults in config.py — not env vars)
#   CONJ_THRESHOLD_KM = 50   → MEDIUM if approach below this
#   CONJ_HIGH_RISK_KM = 10   → HIGH if approach below this
# Change them in config.py if you need different bands for research.
# ---------------------------------------------------------------------------
